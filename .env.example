# ========== 飞书通知 ==========
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_CHAT_ID=your_chat_id
# 机器人 webhook（备用）
FEISHU_WEBHOOK=

# ========== LLM（决策解读，可选） ==========
LLM_BASE_URL=https://api.siliconflow.cn
LLM_API_KEY=your_api_key
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# ========== 数据源 ==========
# akshare 免费无需 token；如未来用 Tushare 填这里
TUSHARE_TOKEN=

# ========== QMT 实盘（阶段四启用） ==========
QMT_PATH=
QMT_ACCOUNT_ID=
QMT_PASSWORD=

# ========== 系统 ==========
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///data/gugu.db
# 运行模式：backtest / paper / live
RUN_MODE=paper
